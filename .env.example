# ================================
# API Keys & Credentials
# ================================

# Groq API (LLM - Llama 3.1 70B)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API
GOOGLE_AI_KEY=your_google_ai_key_here

# OpenAI API (optionnel - fallback)
OPENAI_API_KEY=your_openai_key_here

# ================================
# Database (Supabase)
# ================================

SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ================================
# Redis (Caching & Sessions)
# ================================

REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_URL=your_upstash_redis_url

# ================================
# Frontend Configuration
# ================================

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=MarketAI

# ================================
# LangChain & Monitoring
# ================================

LANGCHAIN_API_KEY=your_langchain_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=marketai-dev

# ================================
# Backend Configuration
# ================================

# Server
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=your_secret_key_change_in_production

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_optional

# ================================
# Payment (Stripe)
# ================================

STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ================================
# Email Configuration (optional)
# ================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=noreply@marketai.com

# ================================
# Web Scraping
# ================================

# DuckDuckGo Search (gratuit)
DUCKDUCKGO_TIMEOUT=5

# ================================
# LLM Configuration
# ================================

# Chunks & Embeddings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Agent Configuration
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120
